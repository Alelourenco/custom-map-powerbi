{
  "dataRoles": [
    {
      "displayName": "State",
      "displayNameKey": "Visual_Role_State",
      "name": "state",
      "kind": "Grouping",
      "description": "State code or name"
    },
    {
      "displayName": "Category",
      "displayNameKey": "Visual_Role_Category",
      "name": "category",
      "kind": "Grouping",
      "description": "Optional category for tooltip and aggregation"
    },
    {
      "displayName": "Primary value",
      "displayNameKey": "Visual_Role_Measure",
      "name": "measure",
      "kind": "Measure",
      "description": "Metric for color and ranking"
    },
    {
      "displayName": "Secondary value",
      "displayNameKey": "Visual_Role_Secondary",
      "name": "secondaryMeasure",
      "kind": "Measure",
      "description": "Optional metric for tooltip and table"
    },
    {
      "displayName": "Tooltip measure",
      "displayNameKey": "Visual_Role_Tooltip",
      "name": "tooltipMeasure",
      "kind": "Measure",
      "description": "Optional additional metric for tooltip"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "state": { "max": 1 },
          "category": { "max": 1 },
          "measure": { "max": 1 },
          "secondaryMeasure": { "max": 1 },
          "tooltipMeasure": { "max": 1 }
        }
      ],
      "categorical": {
        "categories": {
          "select": [
            { "for": { "in": "state" } },
            { "for": { "in": "category" } }
          ],
          "dataReductionAlgorithm": { "top": { "count": 300 } }
        },
        "values": {
          "select": [
            { "bind": { "to": "measure" } },
            { "bind": { "to": "secondaryMeasure" } },
            { "bind": { "to": "tooltipMeasure" } }
          ]
        }
      }
    }
  ],
  "objects": {
    "mapSettings": {
